amr.n_cell = $num_cell_x $num_cell_y $num_cell_z                                            # Number of cells in x, y and z.

hipace.normalized_units = 0                                                                 # Whether the simulation uses the normalized unit system.  
hipace.bxby_solver = explicit                                                               # Solver for Bx and By.

hipace.dt = $time_step # TODO: set automatic timestep
amr.blocking_factor = 1
amr.max_level = $mesh_refinement_maxlevel                                                   # Maximum level of mesh refinement. 

hipace.verbose = 1                                                                          # Level of verbosity. 1 prints only the time steps.

hipace.depos_order_xy = 2
geometry.coord_sys   = 0                                                                    # 0: Cartesian
geometry.prob_lo     = $grid_low_x $grid_low_y $grid_low_z                                  # Lower end of the simulation box in x, y and z.
geometry.prob_hi     = $grid_high_x $grid_high_y $grid_high_z                               # Higher end of the simulation box in x, y and z.

boundary.field       = Dirichlet                                                            # Type of boundary condition used to fill the ghost cells of the fields.
boundary.particle    = Absorbing                                                            # Type of boundary condition used for particles.

my_constants.ref_ratio_x = $ref_ratio_x
my_constants.ref_ratio_y = $ref_ratio_y
my_constants.patch_len_x = $num_cell_x_mr1 * (($grid_high_x / $num_cell_x) / ref_ratio_x)   # Constant used to configure the refined grid.
my_constants.patch_len_y = $num_cell_y_mr1 * (($grid_high_y / $num_cell_y) / ref_ratio_y)   # Constant used to configure the refined grid.

${mesh_refinement_comment}mr_lev1.n_cell = $num_cell_x_mr1 $num_cell_y_mr1                  # Number of cells in x and y for level 1.
${mesh_refinement_comment}mr_lev1.patch_lo = -patch_len_x -patch_len_y $grid_low_z          # Lower end of the refined grid in x, y and z.
${mesh_refinement_comment}mr_lev1.patch_hi =  patch_len_x patch_len_y $grid_high_z          # Upper end of the refined grid in x, y and z.

beams.names = $beam_components # 'driver' or 'driver beam'
beams.insitu_period = 1                                                                     # Period of the beam in-situ diagnostics.

beam.injection_type = from_file                                                             # The injection type for the particle beam.
beam.input_file = $filename_beam                                                            # Name of the beam inout file.
beam.iteration = 0                                                                          # Iteration of the openPMD file to be read in.
beam.do_radiation_reaction = $radiation_reaction                                            # Whether the beam particles undergo energy loss due to classical radiation reaction. 
beam.do_spin_tracking = $do_spin_tracking                                                   # Enable spin tracking.

driver.injection_type = from_file
driver.input_file = $filename_driver
driver.iteration = 0

# external focusing
${external_focusing_comment}beams.external_B(x,y,z,t) = "$external_focusing*y" "-$external_focusing*x" "0.0"

plasmas.names = $plasma_components # 'plasma' or 'electrons ions'
plasmas.prevent_centered_particle = true                                                    # Enabling this setting causes all plasma particles to be initialized half a cell to the side so that no plasma particle will be at the exact center of the domain.
plasmas.reorder_period = 10                                                                 # Reorder particles periodically to speed-up current deposition on GPU for a high-temperature plasma. 
${mesh_refinement_comment}plasmas.fine_transition_cells = 10                                # Number of cells that are used just outside of the fine plasma patch to smoothly transition between the low and high ppc regions. 
${mesh_refinement_comment}plasmas.fine_ppc = ref_ratio_x ref_ratio_y                        # The number of plasma particles per cell in x and y inside the fine plasma patch.
${mesh_refinement_comment}plasmas.fine_patch(x,y) = "x^2/(1.5*patch_len_x)^2 + y^2/(1.5*patch_len_y)^2 < 1" # Specifies a region to increase the number of particles per cell.


# if ion motion disabled
${density_comment1}plasma.density(x,y,z) = $plasma_density                                  # The plasma density as function of x, y and z.
${density_comment2}plasma.density_table_file = $density_table_file                          # Specify the name of a text file containing multiple densities for different positions.
plasma.ppc = 1 1                                                                            # The number of plasma particles per cell in x and y.
plasma.element = electron                                                                   # The physical element of the plasma. Sets charge, mass and, if available, the specific ionization energy of each state.
plasma.do_symmetrize = 1                                                                    # Symmetrizes the plasma in the transverse phase space.


# if ion motion enabled
electrons.element = electron
${density_comment1}electrons.density(x,y,z) = $plasma_density
${density_comment2}electrons.density_table_file = $density_table_file 
electrons.do_symmetrize = 1
electrons.ppc = 1 1
electrons.neutralize_background = 0                                                         # Whether to add a neutralizing background of immobile particles of opposite charge.

ions.element = $ion_species
${density_comment1}ions.density(x,y,z) = $plasma_density
${density_comment2}ions.density_table_file = $density_table_file 
ions.do_symmetrize = 1
ions.ppc = 1 1
ions.neutralize_background = 0
ions.can_ionize = $beam_ionization
ions.initial_ion_level = 1
ions.ionization_product = electrons

diagnostic.names = lev0x
diagnostic.output_period = $output_period                                                   # Output period for standard beam and field diagnostics.
diagnostic.beam_output_period = $output_period                                              # Output period for the beam.
lev0x.diag_type = xz                                                                        # Type of field output.
diagnostic.field_data = Ez ExmBy rho jz_beam                                                # Specifies the fields to be written to file.

hipace.deposit_rho = true                                                                   # If the charge density rho of the plasma should be deposited so that it is available as a diagnostic.
hipace.deposit_rho_individual = true                                                        # The charge density from every plasma species will be deposited into individual fields.
